[user]
    name = Jeet Pavani
    email = <YOUR_GITHUB_EMAIL>

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global

[init]
    defaultBranch = main

[fetch]
    prune = true

[pull]
    rebase = false

[push]
    autoSetupRemote = true
    followTags = true

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true

[color]
    ui = auto
